# FinSight Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── LLM Backend ────────────────────────────────────────────────────────────────
# The default backend is Ollama (local, free, no API key needed).
# If you switch to backend: "openai" in settings.yaml, set this key:
# OPENAI_API_KEY=sk-...

# ── Optional ───────────────────────────────────────────────────────────────────
# HF_TOKEN=hf_...   # Only needed for gated HuggingFace models

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Override default paths if needed ──────────────────────────────────────────
# CHROMA_PERSIST_DIR=indexes/chroma
# BM25_INDEX_PATH=indexes/bm25/bm25.pkl
